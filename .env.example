# Copy to .env and adjust as needed. Never commit .env.

# Run the browser with a visible window (true) or headless (false).
HAVN_HEADFUL=false

# Slow down each Playwright action by N ms (useful when observing a run). 0 = off.
HAVN_SLOWMO=0

# Where run artifacts (screenshots, confirmation records, mapping reports) are written.
HAVN_ARTIFACT_DIR=artifacts

# Base inbox for test enrollments. Real submits use <local>+<runId>@<domain>
# so all test mail lands in one inbox you can check.
HAVN_TEST_EMAIL=ccanning10@gmail.com

# Browserbase (cloud browser) — only needed for `enroll --remote browserbase`, which runs
# the genuinely-headed Chrome in the cloud over a residential proxy instead of this laptop.
# Get these from app.browserbase.com. PROJECT_ID is optional (inferred from the key).
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Debug aid: log 4xx/5xx responses on form/reCAPTCHA endpoints during enroll (status+URL
# only, no bodies). Set to 1 to diagnose a rejected Submit (e.g. the 400 from reCAPTCHA).
HAVN_LOG_NETWORK=
